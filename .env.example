# Copy to .env for local use if your shell/tooling loads dotenv files.
# Do not commit a real .env file.

# AI provider: mock (default, no credentials) or openai.
# AI_PROVIDER=mock
# OPENAI_API_KEY=<your-openai-api-key>
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com

# Backend database connection used by application.yml defaults.
# TESTCASEIQ_DATABASE_URL=jdbc:postgresql://localhost:5432/testcaseiq
# TESTCASEIQ_DATABASE_USERNAME=testcaseiq
# TESTCASEIQ_DATABASE_PASSWORD=testcaseiq_dev_password

# Docker Compose PostgreSQL defaults.
# POSTGRES_DB=testcaseiq
# POSTGRES_USER=testcaseiq
# POSTGRES_PASSWORD=testcaseiq_dev_password

# Redis defaults.
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Auth/security local defaults. Change TESTCASEIQ_JWT_SECRET outside local demo use.
# TESTCASEIQ_SECURITY_ENFORCE_AUTH=false
# TESTCASEIQ_JWT_SECRET=testcaseiq-local-development-jwt-secret-change-me
# TESTCASEIQ_ACCESS_TOKEN_EXPIRATION_SECONDS=3600
