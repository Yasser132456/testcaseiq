# Safe local development example values only.
POSTGRES_DB=testcaseiq
POSTGRES_USER=testcaseiq
POSTGRES_PASSWORD=testcaseiq_dev_password
REDIS_HOST=localhost
REDIS_PORT=6379
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com

# Auth/security local defaults. Change TESTCASEIQ_JWT_SECRET outside local demo use.
TESTCASEIQ_SECURITY_ENFORCE_AUTH=false
TESTCASEIQ_JWT_SECRET=testcaseiq-local-development-jwt-secret-change-me
TESTCASEIQ_ACCESS_TOKEN_EXPIRATION_SECONDS=3600
